# ── Sift configuration ───────────────────────────────────────────────────────
# Copy to .env and edit. Every value is read at call time, so most changes take
# effect without a rebuild.

# ── Auth (pick ONE; the file wins if several are set) ────────────────────────
# 1. Named tokens from a file — the recommended multi-client setup.
#    cp tokens.example.json tokens.json  and put real random strings in it.
SIFT_TOKENS_FILE=/home/sift/tokens.json
# 2. Named tokens inline.
# SIFT_TOKENS=claude:sk-sift-aaa,hermes:sk-sift-bbb
# 3. A single shared bearer.
# SIFT_API_KEY=sk-sift-...
#
# Set NONE of these and the server runs UNAUTHENTICATED. Localhost only —
# it will warn loudly at startup.
#
# Generate a token:  openssl rand -hex 32

# ── Public deployment (docker compose --profile tls) ─────────────────────────
# SIFT_DOMAIN=sift.example.com
# SIFT_ACME_EMAIL=you@example.com
# The base URL baked into published clip links. Defaults from SIFT_DOMAIN.
# SIFT_BASE_URL=https://sift.example.com/clips

# ── Resources ────────────────────────────────────────────────────────────────
# 1 = the 2 vCPU / 4 GB VPS profile: 480p source cap, 5-min transcript windows,
# 24-frame vision budget. Leave it on unless the box is genuinely bigger.
MCP_CONSTRAINED_MODE=1
SIFT_MEM_LIMIT=2g
SIFT_CPUS=2

# Face-follow reframing (MediaPipe, ~300 MB image bloat). 0 = off, and
# reframe="speaker" degrades to a centred crop that says so in the job progress.
SIFT_VISION=0

# ── Rate limiting (per token + client IP). Either at 0 disables. ─────────────
SIFT_RATE_BURST=40
SIFT_RATE_PER_SEC=10

# ── Retention ────────────────────────────────────────────────────────────────
# How long a published LINK resolves. Expiry un-serves a batch; it never deletes
# the clip from the library.
SIFT_TTL_HOURS=168

# ── yt-dlp on a datacenter IP ────────────────────────────────────────────────
# Bot challenges are expected on a VPS. These are the knobs that fix them, and
# fetch_source names them in its error hint when it trips.
# SIFT_COOKIES_PATH=/home/sift/cookies.txt
# SIFT_PROXY=http://user:pass@proxy:8080
#
# A default Docker bridge has NO IPv6 route, but DNS still hands back AAAA records,
# so yt-dlp intermittently picks IPv6 and dies with "Network is unreachable" — it
# works, then it doesn't, on the same URL. Pinning to IPv4 makes it deterministic.
# Set to 0 only on an IPv6-only host, or if you configured IPv6 in Docker.
SIFT_FORCE_IPV4=1

# Docker's embedded DNS can drop the A record for a host and return AAAA only — and a
# bridge network has no IPv6 route, so yt-dlp then cannot connect at all. Real resolvers
# fix it. Change these if your network requires an internal DNS server.
SIFT_DNS1=1.1.1.1
SIFT_DNS2=8.8.8.8

# ── Registry image (needed for the autoupdate profile) ───────────────────────
# SIFT_IMAGE=ghcr.io/azzindani/sift:latest

SIFT_LOG_LEVEL=INFO
